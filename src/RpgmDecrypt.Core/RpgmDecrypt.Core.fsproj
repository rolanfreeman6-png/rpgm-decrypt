    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RootNamespace>RpgmDecrypt.Core</RootNamespace>
    <AssemblyName>RpgmDecrypt.Core</AssemblyName>
  </PropertyGroup>

  <ItemGroup>

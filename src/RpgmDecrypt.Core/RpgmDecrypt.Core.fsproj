    <Compile Include="KeyDiscovery.fs" />
    <Compile Include="VxAceKey.fs" />
    <Compile Include="Format.Mv.fs" />
    <Compile Include="Format.Mz.fs" />
    <Compile Include="Format.Xp.fs" />
    <Compile Include="Format.Vx.fs" />
    <Compile Include="Format.VxAce.fs" />
    <Compile Include="Format.fs" />
    <Compile Include="Walk.fs" />
    <Compile Include="Log.fs" />
    <Compile Include="Report.fs" />
  </ItemGroup>

</Project>

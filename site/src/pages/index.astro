---
/**
 * Home page — full-viewport scenes with document-level scroll-snap.
 * Each scene is its own "step" the wheel pushes the page into:
 *
 *   01 / Works   — hero with BlackHole canvas background + stat block
 *   02 / Catalog — grid of products
 *   03 / Studio  — mission / about block
 *   04 / Roadmap — horizontal sequence of small squares connected by a red
 *                   neon line; each square pinpoints a phase of upcoming work.
 *
 * Implementation matches Hubtown's snap-feel without copying any proprietary
 * JS / WebGL modules. We use:
 *   • document-level `scroll-snap-type: y proximity` (CSS-only)
 *   • IntersectionObserver to flip `.is-active` and fire word-by-word reveals
 *   • shared `.scene__content` styling for fade-out / fade-in scene transitions
 *   • red scroll-progress bar at the top, also driven by scroll
 */
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import Sequence from '../components/Sequence.astro';
import { products } from '../data/products.ts';

const released     = products.filter((p) => p.status === 'released');
const comingSoon   = products.filter((p) => p.status === 'coming-soon');
const ordered      = [...released, ...comingSoon];
const totalShipped = released.length;
const totalIncoming = comingSoon.length;
---
<Base
  title="rolanfreeman — building tools that respect your bytes"
  description="A small catalog of products I ship — standalone binaries and libraries. Data-driven; every entry here is also a real, downloadable thing on GitHub."
  pathname="/"
>
  <!-- ── 01 / WORKS ──────────────────────────────────────────────────────── -->
  <section class="scene scene--hero scene--bleed" id="works">
    <aside class="hero__marker section-marker section-marker--big" aria-hidden="true">
      Works
    </aside>

    <div class="hero__inner scene__content container-full">
      <div class="hero__head">
        <span class="hero__counter counter">01 / Works</span>
        <div class="stats" data-reveal>
          <div class="stat-line">
            <span class="stat-line__num stat-line__num--accent" data-counter={totalShipped}>00</span>
            <span class="stat-line__label">Shipped</span>
            <span class="stat-line__num" data-counter={totalIncoming}>00</span>
            <span class="stat-line__label">In the pipeline</span>
          </div>
        </div>
      </div>

      <h1 class="hero__title display-1 split-text" data-split-text aria-label="Tools that respect your bytes.">
        <span class="word"><span>Tools</span></span>
        <span class="word"><span>that</span></span>
        <span class="word"><span>respect</span></span>
        <span class="word"><span>your</span></span>
        <span class="word"><span>bytes.</span></span>
      </h1>

      <div class="hero__foot">
        <p class="hero__lead lead" data-reveal>
          A small set of products I ship — standalone binaries and libraries,
          each one built like a piece of engineering. Scroll, or click any card
          to read the story and grab the latest release.
        </p>
        <div class="hero__ctas" data-reveal>
          <a class="btn btn-primary btn-arrow btn-lg" href="#catalog">
            See the catalog
          </a>
          <a class="btn btn-ghost btn-arrow" href="https://github.com/rolanfreeman6-png" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        </div>
      </div>

      <a class="hero__cue" href="#catalog" aria-label="Scroll to catalog">
        <span class="hero__cue-line" aria-hidden="true"></span>
        <span class="hero__cue-label">scroll</span>
      </a>
    </div>
  </section>

  <!-- ── 02 / CATALOG ────────────────────────────────────────────────────── -->
  <section class="scene catalog" id="catalog">
    <aside class="catalog__marker section-marker section-marker--big" aria-hidden="true">
      Catalog
    </aside>

    <div class="catalog__inner scene__content container-full">
      <header class="catalog__head">
        <span class="catalog__counter counter">02 / Catalog</span>
        <h2 class="catalog__title display-2" data-reveal>Things I've shipped.</h2>
      </header>

      <div class="catalog__grid">
        {ordered.map((p, i) => (
          <ProductCard product={p} revealDelay={80 + i * 70} index={i + 1} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── 03 / STUDIO ──────────────────────────────────────────────────────── -->
  <section class="scene studio">
    <aside class="studio__marker section-marker section-marker--big" aria-hidden="true">
      Studio
    </aside>

    <div class="studio__inner scene__content container-full">
      <header class="studio__head">
        <span class="studio__counter counter">03 / Studio</span>
        <h2 class="studio__title display-2 split-text" data-split-text aria-label="A solo practice, run with discipline.">
          <span class="word"><span>A</span></span>
          <span class="word"><span>solo</span></span>
          <span class="word"><span>practice,</span></span>
          <span class="word"><span>run</span></span>
          <span class="word"><span>with</span></span>
          <span class="word"><span>discipline.</span></span>
        </h2>
      </header>

      <div class="studio__body">
        <p class="lead" data-reveal>
          I ship small, sharp products and document them like real engineering work —
          not marketing pages. Every release is reproducible, every claim on a
          page is backed by a test, a run, or an honest accounting of what hasn't been.
        </p>
        <p class="lead" data-reveal data-reveal-delay="80">
          If you're after an introduction, the latest project is always the front
          of the catalog. The rest is in the index of finished work, and the
          order of operations lives below.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 04 / ROADMAP (sequence of squares + red neon spine) ─────────────── -->
  <Sequence
    sectionClass="scene roadmap"
    title="Road ahead."
    intro="Right-to-left on the spine, an honest order of operations. Now → next → later. Squares glow brighter the closer in time they get."
    items={[
      { code: '01', label: 'rpgm-decrypt',     detail: 'released · maintained', status: 'now'   },
      { code: '02', label: 'Project TBA',      detail: 'in design',             status: 'next'  },
      { code: '03', label: 'Project TBA II',   detail: 'in research',           status: 'next'  },
      { code: '04', label: '?',                detail: 'yet unnamed',           status: 'later' },
      { code: '05', label: '?',                detail: 'yet unnamed',           status: 'later' },
    ]}
  />
</Base>

<style>
  /* ── 01 / HERO ─────────────────────────────────────────────────────────── */
  .scene--hero {
    position: relative;
    overflow: hidden;
  }
  .hero__marker {
    position: absolute;
    top: clamp(2rem, 8vh, 6rem);
    left: clamp(1rem, 2vw, 2rem);
    z-index: 3;
  }
  .hero__inner {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-9);
    height: 100%;
    padding-block: clamp(3rem, 8vh, 7rem);
  }
  .hero__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .hero__counter { color: var(--neon); }
  .stats .stat-line {
    grid-template-columns: max-content max-content max-content max-content;
    column-gap: var(--space-9);
  }
  .hero__title {
    max-width: 14ch;
    margin-block: var(--space-6) var(--space-7);
  }
  .hero__foot {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-7);
    align-items: end;
  }
  .hero__lead { max-width: 52ch; }
  .hero__ctas {
    display: inline-flex;
    gap: var(--space-3);
    justify-self: end;
    flex-wrap: wrap;
  }
  .hero__cue {
    position: absolute;
    bottom: var(--space-7);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--paper-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-marker);
  }
  .hero__cue-line {
    width: 28px;
    height: 1px;
    background: var(--paper-muted);
  }
  @media (max-width: 920px) {
    .hero__foot { grid-template-columns: 1fr; align-items: start; }
    .hero__ctas { justify-self: start; }
  }

  /* ── 02 / CATALOG ──────────────────────────────────────────────────────── */
  .catalog {
    position: relative;
    align-items: stretch;
  }
  .catalog__marker {
    position: absolute;
    top: var(--space-9);
    left: clamp(1rem, 2vw, 2rem);
    z-index: 3;
  }
  .catalog__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
    height: 100%;
    padding-block: var(--space-section);
  }
  .catalog__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .catalog__counter { color: var(--neon); }
  .catalog__title { max-width: 18ch; }
  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-5) var(--space-5);
    border-top: 1px solid color-mix(in srgb, var(--ink-edge) 100%, transparent);
    padding-top: var(--space-7);
  }
  @media (max-width: 920px) {
    .catalog__marker { display: none; }
  }

  /* ── 03 / STUDIO ───────────────────────────────────────────────────────── */
  .studio {
    position: relative;
  }
  .studio__marker {
    position: absolute;
    top: var(--space-9);
    left: clamp(1rem, 2vw, 2rem);
    z-index: 3;
  }
  .studio__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    max-width: min(1180px, 100%);
  }
  .studio__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .studio__counter { color: var(--neon); }
  .studio__title { max-width: 18ch; }
  .studio__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    border-top: 1px solid color-mix(in srgb, var(--ink-edge) 100%, transparent);
    padding-top: var(--space-7);
    max-width: 70ch;
  }
  @media (max-width: 920px) {
    .studio__marker { display: none; }
  }
</style>

<script>
  /* ── Counter animation: tick any [data-counter] from 0 → n on scene activation ── */
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  if (counters.length > 0) {
    const tick = (el: HTMLElement, target: number): void => {
      const start = performance.now();
      const dur = 1100;
      const step = (now: number): void => {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        const value = Math.max(0, Math.round(target * eased));
        el.textContent = value < 10 ? `0${value}` : String(value);
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        const target = Number(el.dataset.counter ?? '0');
        tick(el, target);
        io.unobserve(el);
      }
    }, { threshold: 0.4 });
    counters.forEach((el) => io.observe(el));
  }
</script>

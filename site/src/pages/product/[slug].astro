---
/**
 * Dynamic product page — one per entry in src/data/products.ts.
 *
 * URL: /product/<slug>. Static pre-render: getStaticPaths returns all slugs.
 *
 * Sections (top → bottom):
 *   • VideoHero  — blurred looped video + poster fallback.
 *   • Anchor #content — article body, scroll-revealed:
 *       – Description rendered from Markdown.
 *   • DownloadBlock  — OS-matched release buttons + GitHub fallback.
 *   • Links strip  — repo, issues, homepage, docs.
 *   • Footer of cards: "Browse other products" — small catalog pills.
 */
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import VideoHero from '../../components/VideoHero.astro';
import DownloadBlock from '../../components/DownloadBlock.astro';
import { marked } from 'marked';
import { products, products as allProducts } from '../../data/products.ts';

export const getStaticPaths = (() => products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }))) satisfies GetStaticPaths;
export const prerender = true;

const { product } = Astro.props;
const ogImage = product.poster;

marked.setOptions({ gfm: true, breaks: false });
const html = marked.parse(product.description, { async: false }) as string;

// for the cross-link strip at the bottom
const siblings = allProducts.filter((p) => p.slug !== product.slug);

const links = product.links ?? {};
const repoUrl = product.repo ? `https://github.com/${product.repo}` : undefined;
const releases = product.repo ? `https://github.com/${product.repo}/releases` : undefined;
---
<Base
  title={`${product.name} — ${product.tagline}`}
  description={product.tagline}
  ogImage={ogImage}
  pathname={`/product/${product.slug}`}
>
  <VideoHero
    videoSrc={product.demoVideo || ''}
    posterSrc={product.poster}
    title={product.name}
    tagline={product.tagline}
  />

  <section id="content" class="section">
    <div class="container-narrow">

      <article class="markdown" data-reveal>
        <Fragment set:html={html} />
      </article>

      <hr class="divider" />

      <DownloadBlock product={product} />
    </div>
  </section>

  {((repoUrl || links.homepage || links.docs || links.issues) && product.status === 'released') && (
    <section class="section section-links">
      <div class="container-narrow">
        <div class="link-strip" data-reveal>
          {repoUrl && (
            <a class="link-strip__item hairline" href={repoUrl} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Source</span>
              <span class="link-strip__name">Repository</span>
              <span class="link-strip__sub">github.com/{product.repo}</span>
            </a>
          )}
          {releases && (
            <a class="link-strip__item hairline" href={releases} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Releases</span>
              <span class="link-strip__name">All releases</span>
              <span class="link-strip__sub">Version history, binaries, notes</span>
            </a>
          )}
          {links.issues && (
            <a class="link-strip__item hairline" href={links.issues} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Support</span>
              <span class="link-strip__name">Issues</span>
              <span class="link-strip__sub">Bug reports, feature requests</span>
            </a>
          )}
          {links.docs && (
            <a class="link-strip__item hairline" href={links.docs} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Docs</span>
              <span class="link-strip__name">Documentation</span>
              <span class="link-strip__sub">Deep dive, guides, references</span>
            </a>
          )}
          {links.homepage && (
            <a class="link-strip__item hairline" href={links.homepage} target="_blank" rel="noopener noreferrer">
              <span class="eyebrow">Web</span>
              <span class="link-strip__name">Homepage</span>
              <span class="link-strip__sub">Project page</span>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {siblings.length > 0 && (
    <section class="section">
      <div class="container">
        <header class="siblings__head" data-reveal>
          <span class="eyebrow">More from the catalog</span>
          <h2 class="siblings__title">Other products</h2>
        </header>
        <ul class="siblings__list" role="list">
          {siblings.map((p, i) => (
            <li class="reveal" style={`--reveal-delay: ${80 + i * 60}ms`}>
              <a class="hairline siblings__pill" href={`/product/${p.slug}`}>
                <span class:list={[ 'chip', p.status === 'coming-soon' ? 'chip-coming' : 'chip-released' ]}>
                  <span class="chip-dot" aria-hidden="true"></span>
                  {p.status === 'coming-soon' ? 'Coming soon' : 'Released'}
                </span>
                <span class="siblings__name">{p.name}</span>
                <span class="siblings__tagline">{p.tagline}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</Base>

<style>
  .article-body { padding-top: var(--space-7); }

  .link-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
  }
  .link-strip__item {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
    background: color-mix(in srgb, var(--void-elevated) 80%, transparent);
  }
  .link-strip__item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }
  .link-strip__name {
    color: var(--text-strong);
    font-weight: 500;
    font-size: var(--text-md);
    letter-spacing: -0.01em;
  }
  .link-strip__sub {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .siblings__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .siblings__title {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .siblings__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .siblings__pill {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-5);
    align-items: center;
    padding: var(--space-4) var(--space-5);
    background: color-mix(in srgb, var(--void-elevated) 80%, transparent);
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    color: inherit;
  }
  .siblings__pill:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-soft);
  }
  .siblings__name {
    color: var(--text-strong);
    font-weight: 500;
  }
  .siblings__tagline {
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: right;
  }
  @media (max-width: 720px) {
    .siblings__pill { grid-template-columns: 1fr; }
    .siblings__tagline { text-align: left; }
  }
</style>

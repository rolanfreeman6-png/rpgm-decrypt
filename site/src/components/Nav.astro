---
/**
 * Site navigation. Sticky on scroll with backdrop-blur.
 * One row of links; no mega-menu. Brand mark "rolanfreeman" on the left.
 */
interface Props {
  pathname?: string;
}
const { pathname = '/' } = Astro.props;
const isHome = pathname.replace(/\/$/, '') === '';
---
<nav class="nav" aria-label="Primary">
  <div class="nav__inner container-full">
    <a href="/" class="nav__brand" aria-label="rolanfreeman — home">
      <span class="nav__brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22">
          <defs>
            <linearGradient id="markGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#ff8a3d"/>
              <stop offset="100%" stop-color="#8a5cff"/>
            </linearGradient>
          </defs>
          <circle cx="12" cy="12" r="9" fill="none" stroke="url(#markGrad)" stroke-width="1.4" opacity="0.7"/>
          <circle cx="12" cy="12" r="5" fill="none" stroke="url(#markGrad)" stroke-width="1.4"/>
          <circle cx="12" cy="12" r="2.4" fill="url(#markGrad)"/>
          <circle cx="12" cy="12" r="1.6" fill="#000"/>
        </svg>
      </span>
      <span class="nav__brand-name">rolanfreeman</span>
    </a>

    <ul class="nav__links" role="list">
      <li>
        <a href="/" aria-current={isHome ? 'page' : undefined} class:list={[ 'nav__link', { 'is-active': isHome } ]}>
          Products
        </a>
      </li>
      <li>
        <a
          href="https://github.com/rolanfreeman6-png"
          rel="noopener noreferrer"
          target="_blank"
          class="nav__link nav__link--external"
        >
          GitHub
          <span aria-hidden="true" class="nav__ext">↗</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--void) 60%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid color-mix(in srgb, var(--void-edge) 40%, transparent);
    transition: background var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-5);
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-strong);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    font-size: var(--text-md);
  }
  .nav__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--violet) 30%, transparent), transparent 70%);
  }
  .nav__brand-name { line-height: 1; }

  .nav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: var(--text-base);
    color: var(--muted);
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }
  .nav__link:hover { color: var(--text); }
  .nav__link.is-active {
    color: var(--text-strong);
    background: color-mix(in srgb, var(--void-elevated) 70%, transparent);
  }
  .nav__ext { font-size: 0.85em; opacity: 0.7; }

  @media (max-width: 540px) {
    .nav__inner { height: 56px; }
    .nav__brand-name { display: none; } /* keep logo only on tiny screens */
  }
</style>

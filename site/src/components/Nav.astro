---
/**
 * Site navigation — editorial, single-row, slim.
 * Sits below the preloader bar (which is in Base.astro).
 * Brand mark + word-label on the left; right side has Products / GitHub.
 */
interface Props {
  pathname?: string;
}
const { pathname = '/' } = Astro.props;
const isHome = pathname.replace(/\/$/, '') === '';
---
<nav class="nav" aria-label="Primary">
  <div class="nav__inner container-full">
    <a href="/" class="nav__brand" aria-label="rolanfreeman — home">
      <span class="nav__brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22">
          <defs>
            <linearGradient id="markGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#d9b774"/>
              <stop offset="100%" stop-color="#b87a3f"/>
            </linearGradient>
          </defs>
          <circle cx="12" cy="12" r="9" fill="none" stroke="url(#markGrad)" stroke-width="1.4" opacity="0.6"/>
          <circle cx="12" cy="12" r="5" fill="none" stroke="url(#markGrad)" stroke-width="1.4"/>
          <circle cx="12" cy="12" r="2.4" fill="url(#markGrad)"/>
          <circle cx="12" cy="12" r="1.6" fill="#0c0b09"/>
        </svg>
      </span>
      <span class="nav__brand-name">rolanfreeman</span>
    </a>

    <ul class="nav__links" role="list">
      <li>
        <a class:list={[ 'nav__link', { 'is-active': isHome } ]} href="/">
          <span class="nav__idx">01</span>
          <span>Works</span>
        </a>
      </li>
      <li>
        <a
          class="nav__link nav__link--external"
          href="https://github.com/rolanfreeman6-png"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="nav__idx">02</span>
          <span>GitHub</span>
          <span aria-hidden="true" class="nav__ext">↗</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--ink) 78%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid color-mix(in srgb, var(--ink-edge) 80%, transparent);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-5);
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-strong);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    font-size: var(--text-md);
  }
  .nav__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
  }
  .nav__brand-name { line-height: 1; }

  .nav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: 8px 14px;
    font-size: var(--text-base);
    font-family: var(--font-display);
    color: var(--paper-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .nav__link:hover { color: var(--text-strong); }
  .nav__link.is-active { color: var(--text-strong); }
  .nav__idx {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--paper-soft);
    letter-spacing: var(--tracking-wide);
  }
  .nav__link.is-active .nav__idx,
  .nav__link:hover .nav__idx { color: var(--gold); }
  .nav__ext { font-size: 0.85em; opacity: 0.7; }

  @media (max-width: 540px) {
    .nav__inner { height: 56px; }
    .nav__brand-name { display: none; }
    .nav__link span:not(.nav__idx) { display: none; }
  }
</style>

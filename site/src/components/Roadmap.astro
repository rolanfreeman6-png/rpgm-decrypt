---
/**
 * Roadmap — horizontal sequence of animated stars connected by a glowing
 * red-neon line. As the section scrolls into view:
 *   • the connecting line draws itself across (stroke-dashoffset → 0)
 *   • stars pop in one by one with stagger
 *   • each star keeps a soft pulsing glow
 *
 * Mobile: stacks vertically; the line becomes a left-edge vertical trace,
 * each star slides in from the left.
 *
 * Edit `milestones` to add / reorder / rename; the rest is reactive.
 */

interface Milestone {
  code: string;          // e.g. "01", "v1.0"
  label: string;         // one-line description
  detail?: string;       // optional secondary line (small, muted)
  /** `now` highlights the current milestone. Future ones are dimmed. */
  status?: 'now' | 'next' | 'later';
}

interface Props {
  title?: string;
  intro?: string;
  milestones?: Milestone[];
}

/** Defaults — override via prop when reusing this component. */
const DEFAULTS: Milestone[] = [
  { code: '01', label: 'rpgm-decrypt',     detail: 'released · maintained', status: 'now'   },
  { code: '02', label: 'Project TBA',      detail: 'in design',             status: 'next'  },
  { code: '03', label: 'Project TBA II',   detail: 'in research',           status: 'next'  },
  { code: '04', label: '?',                detail: 'yet unnamed',           status: 'later' },
];

const {
  title = 'Roadmap',
  intro = 'A short, honest order of operations. Items further right are firmer; items further left are later. Stars glow brighter the closer in time they get.',
  milestones = DEFAULTS,
} = Astro.props;
---
<section class="roadmap section section-lg" id="roadmap" aria-label="Road map of upcoming work">
  <div class="roadmap__inner container-full">
    <header class="roadmap__head">
      <span class="roadmap__counter counter">04 / Roadmap</span>
      <h2 class="roadmap__title display-2" data-reveal>{title}</h2>
      <p class="lead roadmap__intro" data-reveal data-reveal-delay="80">{intro}</p>
    </header>

    <!-- ── horizontal timeline (desktop) ─────────────────────────────────────
         SVG holds the line; the stars are HTML so they can pulse independently. -->
    <div class="roadmap__stage" data-roadmap>
      <div class="roadmap__sky" aria-hidden="true">
        <!-- background tiny stars sprinkled behind the line -->
        {Array.from({ length: 60 }).map((_, i) => (
          <span
            class="sky-star"
            style={`top:${(Math.sin(i * 13.37) * 0.5 + 0.5) * 100}%;left:${(i * 0.83 + (i % 7) * 4) % 100}%;animation-delay:${(i % 12) * 0.18}s;`}
          ></span>
        ))}
      </div>

      <svg
        class="roadmap__line"
        viewBox="0 0 1000 60"
        preserveAspectRatio="none"
        role="presentation"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="rdGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"  stop-color="rgba(255,46,85,0)"  />
            <stop offset="8%"  stop-color="rgba(255,46,85,0.6)" />
            <stop offset="55%" stop-color="rgba(255,46,85,1)"   />
            <stop offset="92%" stop-color="rgba(255,46,85,0.5)" />
            <stop offset="100%" stop-color="rgba(255,46,85,0)" />
          </linearGradient>
          <filter id="rdGlow" x="-50%" y="-200%" width="200%" height="500%">
            <feGaussianBlur stdDeviation="3" />
          </filter>
        </defs>
        <!-- base dim trace -->
        <line x1="0" x2="1000" y1="30" y2="30" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
        <!-- red neon that fills via dashoffset -->
        <line
          x1="0" x2="1000" y1="30" y2="30"
          stroke="url(#rdGrad)"
          stroke-width="1.6"
          stroke-linecap="round"
          class="roadmap__line-fill"
          data-line-fill
          style="stroke-dasharray: 1000; stroke-dashoffset: 1000;"
        />
        <line
          x1="0" x2="1000" y1="30" y2="30"
          stroke="url(#rdGrad)"
          stroke-width="6"
          stroke-linecap="round"
          filter="url(#rdGlow)"
          opacity="0.45"
          class="roadmap__line-fill"
          style="stroke-dasharray: 1000; stroke-dashoffset: 1000;"
        />
      </svg>

      <!-- milestones row -->
      <ol class="roadmap__stars" role="list" data-roadmap-stars>
        {milestones.map((m, i) => {
          const pos = milestones.length === 1 ? 50 : (i / (milestones.length - 1)) * 100;
          const isNow   = m.status === 'now';
          const isLater = m.status === 'later';
          return (
            <li
              class:list={[ 'milestone', { 'is-now': isNow, 'is-later': isLater } ]}
              style={`left:${pos}%`}
              data-stagger={i * 110 + 200}
            >
              <span class="milestone__star" aria-hidden="true">
                <span class="milestone__core"></span>
                <span class="milestone__halo"></span>
                <span class="milestone__pulse"></span>
              </span>
              <span class="milestone__code">{m.code}</span>
              <span class="milestone__label">{m.label}</span>
              {m.detail && <span class="milestone__detail">{m.detail}</span>}
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>

<style>
  .roadmap {
    position: relative;
    border-top: 1px solid color-mix(in srgb, var(--ink-edge) 100%, transparent);
  }
  .roadmap__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }
  .roadmap__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 64ch;
  }
  .roadmap__title { max-width: 18ch; }
  .roadmap__intro { max-width: 56ch; }

  /* ── the stage that holds the timeline + stars + sky ────────────────── */
  .roadmap__stage {
    position: relative;
    height: clamp(360px, 38vw, 480px);
    border-radius: 0;
    overflow: visible;
  }
  /* tiny twinkling background stars sprinkled behind the line */
  .roadmap__sky {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .sky-star {
    position: absolute;
    width: 1.6px;
    height: 1.6px;
    border-radius: 50%;
    background: rgba(255, 240, 240, 0.55);
    box-shadow: 0 0 6px rgba(255, 200, 200, 0.4);
    animation: sky-twinkle 6s ease-in-out infinite;
  }
  @keyframes sky-twinkle {
    0%, 100% { opacity: 0.2; transform: scale(0.7); }
    50%      { opacity: 0.9; transform: scale(1.0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sky-star { animation: none; opacity: 0.5; transform: none; }
  }

  /* the connecting red neon lines (drawn across via JS dashoffset) */
  .roadmap__line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    width: 100%;
    height: 60px;
    transform: translateY(-50%);
    z-index: 1;
    overflow: visible;
  }
  .roadmap__line-fill { transition: stroke-dashoffset 1.6s var(--ease-out); }

  /* ── milestone stars pinned along the line ─────────────────────────── */
  .roadmap__stars {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    z-index: 2;
  }
  .milestone {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 160px;
    text-align: center;
    /* hidden until JS reveals */
    opacity: 0;
    transform: translate(-50%, -30%);
    transition:
      opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
    transition-delay: var(--stagger, 0ms);
  }
  .milestone.is-revealed {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  /* the visual star itself — three layered parts */
  .milestone__star {
    position: relative;
    width: 32px;
    height: 32px;
    display: block;
  }
  .milestone__core {
    position: absolute;
    inset: 50%;
    width: 8px;
    height: 8px;
    margin: -4px 0 0 -4px;
    background: var(--neon);
    border-radius: 50%;
    box-shadow:
      0 0 8px var(--neon),
      0 0 18px color-mix(in srgb, var(--neon) 70%, transparent),
      0 0 32px color-mix(in srgb, var(--neon) 50%, transparent);
  }
  .milestone__halo {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--neon) 70%, transparent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--neon) 50%, transparent) inset;
  }
  .milestone__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--neon) 60%, transparent) 0%, transparent 60%);
    animation: milestone-pulse 2.6s var(--ease-out) infinite;
    pointer-events: none;
  }
  @keyframes milestone-pulse {
    0%   { transform: scale(0.6); opacity: 0.9; }
    70%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .milestone__pulse { animation: none; opacity: 0; }
  }

  .milestone__code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--neon);
    margin-top: var(--space-3);
  }
  .milestone__label {
    color: var(--text-strong);
    font-weight: 500;
    font-size: var(--text-md);
    line-height: 1.2;
  }
  .milestone__detail {
    color: var(--paper-muted);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
  }

  .milestone.is-later {
    opacity: 0;
    filter: saturate(0.5);
  }
  .milestone.is-later .milestone__core {
    background: var(--paper-soft);
    box-shadow: 0 0 4px rgba(255, 255, 255, 0.15);
  }
  .milestone.is-later .milestone__halo {
    border-color: color-mix(in srgb, var(--paper-soft) 60%, transparent);
    box-shadow: none;
  }
  .milestone.is-later .milestone__code { color: var(--paper-soft); }
  .milestone.is-later .milestone__pulse { display: none; }

  /* milestone label sits BELOW the line */
  .milestone { padding-top: 36px; }
  .milestone__code,
  .milestone__label,
  .milestone__detail { order: 2; }

  /* ── mobile: stack vertically, line is on the left ─────────────────── */
  @media (max-width: 720px) {
    .roadmap__stage { height: auto; padding-left: 28px; }
    .roadmap__sky { inset: 0 0 0 0; }
    .roadmap__line {
      top: 0; bottom: 0; left: 0; right: auto;
      width: 28px; height: 100%;
      transform: none;
    }
    .roadmap__stars { position: relative; inset: auto; }
    .roadmap__stars::before {
      content: '';
      position: absolute;
      left: -28px;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(180deg, transparent 0%, rgba(255,46,85,0.4) 50%, transparent 100%);
    }
    .milestone {
      position: relative;
      top: auto;
      left: auto !important;
      transform: none !important;
      align-items: flex-start;
      text-align: left;
      width: 100%;
      padding: var(--space-5) 0;
      margin-bottom: var(--space-5);
    }
    .milestone.is-revealed { transform: none; }
    .milestone__star {
      position: absolute;
      left: -36px;
      top: var(--space-5);
      width: 16px; height: 16px;
    }
    .milestone__star .milestone__core { width: 6px; height: 6px; margin: -3px 0 0 -3px; }
    .milestone__code,
    .milestone__label,
    .milestone__detail { order: 0; }
  }
</style>

<script>
  /* Reveal each milestone + draw the line. Single IntersectionObserver. */
  const stage = document.querySelector<HTMLElement>('[data-roadmap]');
  if (stage) {
    const line = stage.querySelectorAll<SVGLineElement>('[data-line-fill]');
    const stars = stage.querySelectorAll<HTMLElement>('.milestone');

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      line.forEach((l) => l.style.setProperty('stroke-dashoffset', '0'));
      stars.forEach((s) => s.classList.add('is-revealed'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            // stagger the line drawing
            line.forEach((l, i) => {
              const total = Number(l.getTotalLength?.() ?? 1000);
              l.style.strokeDasharray = String(total);
              window.setTimeout(() => {
                l.style.strokeDashoffset = '0';
              }, 100 + i * 80);
            });
            // then pop each star in
            stars.forEach((s, i) => {
              window.setTimeout(() => s.classList.add('is-revealed'), 220 + i * 110);
            });
            io.unobserve(entry.target);
          }
        },
        { threshold: 0.25 },
      );
      io.observe(stage);
    }
  }
</script>

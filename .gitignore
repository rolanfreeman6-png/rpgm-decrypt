# Build artifacts
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
.vs/

# ...but ocaml/bin/ is the OCaml CLI *source* directory, not build output.
# The generic bin/ rule above would otherwise drop the entire CLI from the repo.
!ocaml/bin/
!ocaml/bin/**

# Test output
TestResults/
coverage/
*.coverage
coverage.xml
*.trx

# ...but ocaml/coverage/ is the committed bisect_ppx coverage report, not build output.
!ocaml/coverage/
!ocaml/coverage/**

# Native AOT publish
publish/
out/
artifacts/

# GitHub Actions
.github/workflows/*.local.yml

# Rider/VS settings
.idea/
*.DotSettings.user

# logs
*.log
logs/

# OS junk
Thumbs.db
.DS_Store

# Real-world RPG Maker game files (we never commit user-provided content)
fixtures-real/
games-real/

# Generated synthetic-game smoke artifacts (held on D:/rpgm-decrypt-tmp, never in repo)
smoke-CLI/

# secrets
*.pfx
*.key
secrets/

# node-style (just in case)
node_modules/
